# Example environment configuration for Gemma 4 Challenge
# Copy this file to .env and fill in your values

# Gemma 4 model to use (e.g., gemma-4-base, gemma-4-large, gemma-4-xl)
MODEL=gemma-4-base

# Temperature for model output randomness (0.0 - 1.0)
TEMPERATURE=0.7

# Maximum number of tokens in the response
MAX_TOKENS=512

# (Optional) API keys or other secrets can be added here
# OPENAI_API_KEY=your-key-here
# STRANDS_API_KEY=your-strands-key-here

# (Optional) Async/agent settings
# AGENT_TIMEOUT=30
