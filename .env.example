# Example environment configuration for Gemma 4 Challenge
# Copy this file to .env and fill in your values

# --- Provider and Model Selection ---
# Supported providers: Ollama, Vertex AI, Bedrock, Azure OpenAI
PROVIDER=Ollama

# Model to use (see README for dynamic options per provider)
# Ollama: gemma:2b, gemma:7b, gemma:2b-instruct, gemma:7b-instruct
# Vertex AI: gemma-4-vertex-standard, gemma-4-vertex-pro
# Bedrock: gemma-4-bedrock-lite, gemma-4-bedrock-adv
# Azure OpenAI: gemma-4-azure-basic, gemma-4-azure-premium
MODEL=gemma:2b

# --- Generation Parameters ---
# Temperature for model output randomness (0.0 - 1.0)
TEMPERATURE=0.7
# Maximum number of tokens in the response
MAX_TOKENS=512
# Aspect ratio (e.g., 16:9, 3:2, 4:3, 5:4, Square, Portrait)
ASPECT_RATIO=16:9
# Formatting (Default, Landscape, Portrait, Square)
FORMATTING=Default
# Color guidance (hex color, e.g., #ffffff)
COLOR_GUIDANCE=#ffffff
# Exclude items (comma-separated)
EXCLUDE_ITEMS=

# --- Local Ollama Configuration (default) ---
# No API key required for local Ollama
# If using remote providers, set the appropriate API key(s) below:
# OPENAI_API_KEY=your-key-here
# VERTEX_API_KEY=your-vertex-key-here
# BEDROCK_API_KEY=your-bedrock-key-here
# AZURE_OPENAI_API_KEY=your-azure-key-here
# STRANDS_API_KEY=your-strands-key-here

# --- (Optional) Async/agent settings ---
# AGENT_TIMEOUT=30
